<Window x:Class="TerminalHost.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TerminalHost 设置" Width="760" Height="650" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="#020617" Foreground="#E2E8F0">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#CBD5E1" /><Setter Property="VerticalAlignment" Value="Center" /></Style>
        <Style TargetType="TextBox"><Setter Property="Margin" Value="8,4" /><Setter Property="Padding" Value="7,5" /><Setter Property="Background" Value="#0F172A" /><Setter Property="Foreground" Value="#E2E8F0" /><Setter Property="CaretBrush" Value="#38BDF8" /><Setter Property="BorderBrush" Value="#334155" /><Setter Property="SelectionBrush" Value="#0369A1" /></Style>
        <Style TargetType="PasswordBox"><Setter Property="Background" Value="#0F172A" /><Setter Property="Foreground" Value="#E2E8F0" /><Setter Property="CaretBrush" Value="#38BDF8" /><Setter Property="BorderBrush" Value="#334155" /></Style>
        <Style TargetType="ComboBox"><Setter Property="Margin" Value="8,4" /><Setter Property="Padding" Value="6,4" /><Setter Property="Background" Value="#0F172A" /><Setter Property="Foreground" Value="#E2E8F0" /><Setter Property="BorderBrush" Value="#334155" /></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="#E2E8F0" /><Setter Property="Margin" Value="8,6" /></Style>
        <Style TargetType="GroupBox"><Setter Property="Foreground" Value="#E2E8F0" /><Setter Property="Margin" Value="8" /><Setter Property="Padding" Value="8" /><Setter Property="BorderBrush" Value="#334155" /></Style>
        <Style TargetType="Button"><Setter Property="Padding" Value="16,7" /><Setter Property="Margin" Value="6" /><Setter Property="Foreground" Value="#E2E8F0" /><Setter Property="Background" Value="#1E293B" /><Setter Property="BorderBrush" Value="#475569" /></Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CBD5E1" /><Setter Property="Background" Value="#111827" /><Setter Property="Padding" Value="13,7" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1E293B" /><Setter Property="Foreground" Value="#FFFFFF" /></Trigger>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#38BDF8" /><Setter Property="Foreground" Value="#082F49" /><Setter Property="FontWeight" Value="SemiBold" /></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <TabControl Grid.Row="0" Background="#0F172A" Foreground="#E2E8F0" BorderBrush="#334155">
            <TabItem Header="常规">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="WebSocket API 端口" /><TextBox x:Name="ApiPortBox" Grid.Row="0" Grid.Column="1" />
                        <TextBlock Grid.Row="1" Text="默认 Shell" />
                        <ComboBox x:Name="DefaultShellBox" Grid.Row="1" Grid.Column="1">
                            <ComboBoxItem Content="PowerShell 7" Tag="pwsh" /><ComboBoxItem Content="Windows PowerShell" Tag="powershell" /><ComboBoxItem Content="CMD" Tag="cmd" />
                        </ComboBox>
                        <TextBlock Grid.Row="2" Text="默认工作目录" /><TextBox x:Name="DefaultDirectoryBox" Grid.Row="2" Grid.Column="1" />
                        <TextBlock Grid.Row="3" Text="终端字体" /><TextBox x:Name="FontFamilyBox" Grid.Row="3" Grid.Column="1" />
                        <TextBlock Grid.Row="4" Text="终端字号（9–32）" /><TextBox x:Name="FontSizeBox" Grid.Row="4" Grid.Column="1" />
                        <TextBlock Grid.Row="5" Text="终端主题" />
                        <ComboBox x:Name="ThemeBox" Grid.Row="5" Grid.Column="1"><ComboBoxItem Content="深色" Tag="dark" /><ComboBoxItem Content="浅色" Tag="light" /></ComboBox>
                        <CheckBox x:Name="RestoreSessionsBox" Grid.Row="6" Grid.ColumnSpan="2" Content="启动时恢复上次的标签页" />
                        <CheckBox x:Name="MinimizeToTrayBox" Grid.Row="7" Grid.ColumnSpan="2" Content="关闭窗口时最小化到系统托盘" />
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="MCP">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <CheckBox x:Name="McpEnabledBox" Grid.Row="0" Grid.ColumnSpan="2" Content="启动 TerminalHost 时自动启用 MCP" />
                    <TextBlock Grid.Row="1" Text="传输方式" />
                    <ComboBox x:Name="McpTransportBox" Grid.Row="1" Grid.Column="1" SelectionChanged="McpTransportBox_SelectionChanged"><ComboBoxItem Content="Streamable HTTP（共享服务）" Tag="http" /><ComboBoxItem Content="stdio（由客户端启动）" Tag="stdio" /></ComboBox>
                    <TextBlock Grid.Row="2" Text="HTTP 端口" /><TextBox x:Name="McpPortBox" Grid.Row="2" Grid.Column="1" />
                    <TextBlock Grid.Row="3" Text="HTTP Bearer Token" /><PasswordBox x:Name="McpTokenBox" Grid.Row="3" Grid.Column="1" Margin="8,4" Padding="7,5" />
                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Margin="8,18,8,0" Foreground="#98A2B3" TextWrapping="Wrap"
                               Text="HTTP 仅监听 127.0.0.1。留空令牌表示本机客户端无需 Bearer Token；stdio 模式由 MCP 客户端使用 TerminalHost.exe --mcp-stdio 启动。" />
                </Grid>
            </TabItem>
            <TabItem Header="安全">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <GroupBox Header="允许的 MCP 工具"><WrapPanel x:Name="ToolListPanel" /></GroupBox>
                        <GroupBox Header="允许的工作目录（每行一个；留空表示不限制）">
                            <TextBox x:Name="AllowedDirectoriesBox" Height="120" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </GroupBox>
                        <GroupBox Header="危险命令规则（每行一条，* 表示任意字符）">
                            <TextBox x:Name="DangerousCommandsBox" Height="150" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </GroupBox>
                        <CheckBox x:Name="ConfirmDangerousBox" Content="危险命令必须显式设置 confirmDangerous=true" />
                        <TextBlock Margin="10" Foreground="#F5B971" TextWrapping="Wrap"
                                   Text="目录限制约束 MCP 创建会话的初始工作目录；Shell 启动后仍拥有当前 Windows 用户权限。所有 MCP 授权和写入操作都会写入审计日志。" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" IsCancel="True" /><Button Content="保存" IsDefault="True" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
