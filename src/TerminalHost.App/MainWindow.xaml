<Window x:Class="TerminalHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TerminalHost v1.0.0" Icon="Assets/terminalhost.ico" Width="1180" Height="760"
        MinWidth="760" MinHeight="480"
        Background="#020617">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#334155" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#0F172A" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="CaretBrush" Value="#38BDF8" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="SelectionBrush" Value="#0369A1" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Background" Value="#475569" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#475569" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#0F172A" Foreground="#E2E8F0" Padding="4,2">
            <Menu.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#0F172A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#0F172A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F4F6FA" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0F172A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#0F172A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F4F6FA" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#155E75" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#747C8C" />
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#F4F6FA" />
                    <Setter Property="Background" Value="#0F172A" />
                    <Setter Property="Padding" Value="10,5" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="HeaderBorder" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                            <Path x:Name="SubmenuArrow" Grid.Column="1" Margin="14,0,2,0" VerticalAlignment="Center"
                                                  Data="M 0 0 L 4 4 L 0 8 Z" Fill="{TemplateBinding Foreground}" Visibility="Collapsed" />
                                        </Grid>
                                    </Border>
                                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" Placement="Right"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           PopupAnimation="Fade">
                                        <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" Padding="3">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="Role" Value="TopLevelHeader"><Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" /></Trigger>
                                    <Trigger Property="Role" Value="TopLevelItem"><Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" /></Trigger>
                                    <Trigger Property="Role" Value="SubmenuHeader"><Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" /></Trigger>
                                    <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="HeaderBorder" Property="Background" Value="#334155" /><Setter Property="Foreground" Value="#FFFFFF" /></Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True"><Setter TargetName="HeaderBorder" Property="Background" Value="#155E75" /><Setter Property="Foreground" Value="#FFFFFF" /></Trigger>
                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="#747C8C" /></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style x:Key="FullWidthMenuSeparatorStyle" TargetType="Separator">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Separator">
                                <Grid MinWidth="96" Height="9">
                                    <Border Height="1" Margin="8,4" Background="#334155"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Menu.Resources>
            <MenuItem Header="文件">
                <MenuItem Header="设置..." Click="SettingsMenuItem_Click" />
                <Separator Style="{StaticResource FullWidthMenuSeparatorStyle}" />
                <MenuItem Header="退出" Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="诊断信息" Click="DiagnosticsMenuItem_Click" />
                <MenuItem Header="关于 TerminalHost" Click="AboutMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="#111827" Padding="10" BorderBrush="#334155" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="ShellComboBox" Grid.Column="0" Height="32" Margin="0,0,8,0" SelectedIndex="0">
                    <ComboBoxItem Content="PowerShell 7 (pwsh)" Tag="pwsh" />
                    <ComboBoxItem Content="Windows PowerShell 5.1" Tag="powershell" />
                    <ComboBoxItem Content="CMD" Tag="cmd" />
                </ComboBox>

                <TextBox x:Name="WorkingDirectoryTextBox" Grid.Column="1" Height="32" Margin="0,0,8,0"
                         VerticalContentAlignment="Center" ToolTip="工作目录" />
                <Button x:Name="NewTabButton" Grid.Column="2" Content="+ 新标签" Height="32" Padding="14,0" Margin="0,0,8,0" Click="NewTabButton_Click" />
                <Button x:Name="StartButton" Grid.Column="3" Content="启动/重启" Height="32" Padding="14,0" Margin="0,0,8,0" Click="StartButton_Click" />
                <Button x:Name="StopButton" Grid.Column="4" Content="停止" Height="32" Padding="14,0" Margin="0,0,8,0" Click="StopButton_Click" />
                <Button x:Name="ClearButton" Grid.Column="5" Content="清屏" Height="32" Padding="14,0" Click="ClearButton_Click" />
                <CheckBox x:Name="McpToggle" Grid.Column="6" Content="启用 MCP" Margin="14,0,2,0"
                          VerticalAlignment="Center" Foreground="#CBD5E1"
                          ToolTip="静默启动本机 HTTP MCP 服务（127.0.0.1:8766）" />
            </Grid>
        </Border>

        <TabControl x:Name="TerminalTabs" Grid.Row="2" Margin="0" Background="#020617"
                    BorderThickness="0" SelectionChanged="TerminalTabs_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#CBD5E1" />
                    <Setter Property="Background" Value="#111827" />
                    <Setter Property="Padding" Value="15,8" />
                    <Setter Property="BorderBrush" Value="#334155" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0,1,1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#1E293B" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#155E75" />
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0E7490" />
                                        <Setter Property="Foreground" Value="#F8FAFC" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
        </TabControl>

        <Border Grid.Row="3" Background="#111827" Padding="10,7" BorderBrush="#334155" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Row="0" Grid.Column="0" Foreground="#CBD5E1" VerticalAlignment="Center" Text="正在初始化…" />
                <TextBlock x:Name="VersionText" Grid.Row="0" Grid.Column="1" Foreground="#64748B" VerticalAlignment="Center" Margin="10,0,0,0" />
                <TextBlock x:Name="ApiText" Grid.Row="0" Grid.Column="2" Foreground="#94A3B8" VerticalAlignment="Center" Margin="10,0" />
                <Button x:Name="CopyApiButton" Grid.Row="0" Grid.Column="3" Content="复制 API 信息" Padding="10,3" Click="CopyApiButton_Click" />

                <TextBlock x:Name="SessionIdText" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,7,10,0"
                           FontFamily="Consolas" Text="Session ID：—" />
                <Button x:Name="CopySessionIdButton" Grid.Row="1" Grid.Column="3" Margin="0,6,0,0"
                        Content="复制 Session ID" Padding="10,3" IsEnabled="False"
                        Click="CopySessionIdButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
