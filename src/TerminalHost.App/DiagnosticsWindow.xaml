<Window x:Class="TerminalHost.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TerminalHost 诊断信息" Width="820" Height="620" WindowStartupLocation="CenterOwner"
        Background="#111318" Foreground="#F4F6FA">
    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <TextBox x:Name="ReportBox" Grid.Row="0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13" Background="#0D0F13" Foreground="#D9DDE6" Padding="10" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="刷新" Padding="16,7" Margin="6" Click="RefreshButton_Click" />
            <Button Content="复制诊断信息" Padding="16,7" Margin="6" Click="CopyButton_Click" />
            <Button Content="关闭" Padding="16,7" Margin="6" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
